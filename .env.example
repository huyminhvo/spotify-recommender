SPOTIPY_CLIENT_ID=your_client_id_here
SPOTIPY_CLIENT_SECRET=your_client_secret_here
# Local Streamlit URL. In production use the exact HTTPS app URL registered
# in the Spotify developer dashboard (for example https://your-app.streamlit.app/).
SPOTIPY_REDIRECT_URI=http://127.0.0.1:8501/
# Optional short-lived user token for the offline playlist-membership builder.
# SPOTIFY_USER_ACCESS_TOKEN=your_playlist_read_token
