# auto-detect text files and normalize to LF in the repo
* text=auto eol=lf

# explicitly enforce LF for Python and Markdown files
*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf

# keep binary files untouched
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.csv binary
*.parquet binary
*.pkl binary

# Deployment catalog artifacts are large binary assets fetched through Git LFS.
data/catalog/*.parquet filter=lfs diff=lfs merge=lfs -text
